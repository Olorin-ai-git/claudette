{
  "name": "claudette-setup",
  "version": "1.0.0",
  "description": "Companion CLI to pair your Mac with the Claudette mobile app",
  "type": "commonjs",
  "bin": {
    "claudette-setup": "bin/claudette-setup.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claudette",
    "ssh",
    "pairing",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0",
    "qrcode": "^1.5.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/qrcode": "^1.5.6",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
